{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./build",
    "noEmit": false,
    "module": "CommonJS",
    "moduleResolution": "node",
    "isolatedModules": false,
    "resolveJsonModule": true,
    "esModuleInterop": true
  },
  "include": ["server.ts", "api/**/*.ts", "types.ts"],
  "exclude": ["node_modules", "dist"]
}