{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./build",
    "noEmit": false,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "isolatedModules": false,
    "resolveJsonModule": true,
    "esModuleInterop": true
  },
  "include": ["server.ts", "api/users/index.ts", "types.ts"],
  "exclude": ["node_modules", "dist"]
}
